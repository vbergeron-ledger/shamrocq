(define add (lambdas (n m) (+ n m)))
  
(define mul (lambdas (n m) (* n m)))
  
(define sub (lambdas (n m) (if (< n m) 0 (- n m))))
  
(define eqb (lambdas (n m) (if (= n m) `(True) `(False))))
  
(define ltb (lambdas (n m) (if (< n m) `(True) `(False))))

(define buf_length (lambda (b) (bytes-len b)))

(define buf_get (lambdas (b i) (bytes-get b i)))

(define pure (lambdas (a st) `(Inl ,`(Pair ,st ,a))))

(define fail (lambdas (e _) `(Inr ,e)))

(define bind (lambdas (p f st)
  (match (p st)
     ((Inl p0) (match p0
                  ((Pair st~ a) (@ f a st~))))
     ((Inr e) `(Inr ,e)))))

(define read_u8 (lambda (st)
  (match (@ ltb (match st
                   ((Mk_pstate _ ps_off) ps_off))
           (buf_length (match st
                          ((Mk_pstate ps_buf _) ps_buf))))
     ((True) `(Inl ,`(Pair ,`(Mk_pstate
       ,(match st
           ((Mk_pstate ps_buf _) ps_buf))
       ,`((lambda (n) (+ n 1)) ,(match st
                                   ((Mk_pstate _ ps_off) ps_off))))
       ,(@ buf_get (match st
                      ((Mk_pstate ps_buf _) ps_buf))
          (match st
             ((Mk_pstate _ ps_off) ps_off))))))
     ((False) `(Inr ,`(UnexpectedEOF))))))

